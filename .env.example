SPOTSELF_ADDR=:8080
SPOTSELF_DATA_DIR=./data
SPOTSELF_PUBLIC_URL=http://localhost:8080
SPOTSELF_MAX_UPLOAD_MB=64
# Required for production. Write/admin API calls must send: Authorization: Bearer <token>
SPOTSELF_ADMIN_TOKEN=
# Development only. Set true to allow admin writes without SPOTSELF_ADMIN_TOKEN.
SPOTSELF_ALLOW_NO_AUTH=false
SPOTSELF_MAX_IMAGE_PIXELS=24000000
